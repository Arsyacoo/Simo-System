{
  "name": "simo-mugi-jaya",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:full": "concurrently -k -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "npm --prefix backend run test",
    "db:seed": "npm --prefix backend run db:seed"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
